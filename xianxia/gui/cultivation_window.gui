								visible = "[GetScriptedGui('show_star_shattering').IsShown(GuiScope.SetRoot(Character.MakeScope).End)]"
								text = "[GetTrait('cultivation_star_shattering').GetName( GetPlayer.Self )]"
							}
							
							text_single = {
								layoutpolicy_horizontal = expanding
								default_format = "#high"
								
								visible = "[GetScriptedGui('show_integration').IsShown(GuiScope.SetRoot(Character.MakeScope).End)]"
								text = "[GetTrait('cultivation_integration').GetName( GetPlayer.Self )]"
							}
							
							text_single = {
								layoutpolicy_horizontal = expanding
								default_format = "#high"
								
								visible = "[GetScriptedGui('show_four_axis').IsShown(GuiScope.SetRoot(Character.MakeScope).End)]"
								text = "[GetTrait('cultivation_four_axis').GetName( GetPlayer.Self )]"
							}
							
							text_single = {
								layoutpolicy_horizontal = expanding
								default_format = "#high"
								
								visible = "[GetScriptedGui('show_heavenly_being').IsShown(GuiScope.SetRoot(Character.MakeScope).End)]"
								text = "[GetTrait('cultivation_heavenly_being').GetName( GetPlayer.Self )]"
							}
							
							text_single = {
								layoutpolicy_horizontal = expanding
								default_format = "#high"
								
								visible = "[GetScriptedGui('show_nascent_soul').IsShown(GuiScope.SetRoot(Character.MakeScope).End)]"
								text = "[GetTrait('cultivation_nascent_soul').GetName( GetPlayer.Self )]"
							}
							
							text_single = {
								layoutpolicy_horizontal = expanding
