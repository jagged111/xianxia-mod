							text = "Realm:"
							min_width = 100
						}
						
						# FLOWCONTAINER with ignoreinvisible = yes
						# This makes invisible children not take up space!
						flowcontainer = {
							ignoreinvisible = yes
							layoutpolicy_horizontal = expanding
							
							text_single = {
								layoutpolicy_horizontal = expanding
								default_format = "#high"
								
								visible = "[GetScriptedGui('show_true_immortal').IsShown(GuiScope.SetRoot(Character.MakeScope).End)]"
								text = "[GetTrait('cultivation_true_immortal').GetName( GetPlayer.Self )]"
							}
							
							text_single = {
								layoutpolicy_horizontal = expanding
								default_format = "#high"
								
								visible = "[GetScriptedGui('show_entering_nirvana').IsShown(GuiScope.SetRoot(Character.MakeScope).End)]"
								text = "[GetTrait('cultivation_entering_nirvana').GetName( GetPlayer.Self )]"
							}
							
							text_single = {
								layoutpolicy_horizontal = expanding
								default_format = "#high"
								
								visible = "[GetScriptedGui('show_sacred_vessel').IsShown(GuiScope.SetRoot(Character.MakeScope).End)]"
								text = "[GetTrait('cultivation_sacred_vessel').GetName( GetPlayer.Self )]"
							}
							
							text_single = {
								layoutpolicy_horizontal = expanding
