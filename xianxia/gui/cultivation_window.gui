								text = "Mortal"
							}
						}
					}
				}				
				
				### CHARACTER INFO ###
				vbox = {
					visible = "[GetPlayer.MakeScope.Var('cultivation_right_partner').IsSet]"
					datacontext = "[GetPlayer.MakeScope.Var('cultivation_right_partner').GetCharacter]"
					layoutpolicy_horizontal = expanding
					spacing = 15
